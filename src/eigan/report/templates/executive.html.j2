{% extends "base_corporate.html.j2" %}
{% block doctitle %}Relatório Executivo de Riscos{% endblock %}
{% block cover_kind %}Relatório Executivo{% endblock %}
{% block cover_title %}Relatório Executivo de Riscos{% endblock %}
{% block content %}

  <h2>1. Sumário executivo {% if executive_ai %}<span class="tag ai">gerado por IA</span>{% endif %}</h2>
  <div class="split">
    <div style="flex:0 0 auto">{{ gauge_svg|safe }}</div>
    <div style="flex:1">
      <p>{{ executive_summary }}</p>
      <p class="muted small">Score de postura
        <strong style="color:{{ security_score.color }}">{{ security_score.score }}/100 · nota
        {{ security_score.grade }} ({{ security_score.label }})</strong> — heurística
        determinística (severidade + CISA KEV); não é certificação de conformidade.</p>
    </div>
  </div>

  <h2>2. Postura de risco</h2>
  <div class="split">
    <div style="flex:0 0 auto">{{ donut_svg|safe }}</div>
    <div style="flex:1">
      <div class="grid" style="grid-template-columns: repeat(5,1fr)">
        {% for sev in ["critical","high","medium","low","info"] %}
        <div class="kpi"><div class="n" style="color:{{ sev_colors[sev] }}">{{ summary[sev] }}</div>
          <div class="l">{{ sev }}</div></div>
        {% endfor %}
      </div>
      <p class="muted small">Ativos avaliados: {{ correlations|length }} ·
        Em <strong>CISA KEV</strong> (exploração ativa conhecida): {{ kev_count }}{% if not feeds.kev %}
        <span class="tag unv">KEV UNVERIFIED</span>{% endif %}
        {% if inventory_summary %}<br>Inventário: {{ inventory_summary.assets }} ativo(s) ·
        {{ inventory_summary.with_open_ports }} com portas · {{ inventory_summary.with_web }} com web ·
        {{ inventory_summary.total_ports }} porta(s).{% endif %}</p>
    </div>
  </div>

  <h2>3. Riscos prioritários</h2>
  <table>
    <thead><tr><th>#</th><th>Risco</th><th>Sev.</th><th>Ativo</th><th>Risco</th><th>EPSS</th><th>KEV</th></tr></thead>
    <tbody>
    {% for f in top_risks %}
      <tr>
        <td>{{ loop.index }}</td><td>{{ f.title }}</td>
        <td><span class="sev sev-{{ f.severity.value }}">{{ f.severity.value|upper }}</span></td>
        <td><code>{{ f.affected_asset }}</code></td>
        <td>{{ "%.0f"|format(f.risk_rank) }}</td>
        <td>{% if f.risk and f.risk.epss_verified %}{{ "%.3f"|format(f.risk.epss) }}{% else %}<span class="tag unv">UNVERIFIED</span>{% endif %}</td>
        <td>{% if f.risk and f.risk.kev %}<span class="tag kev">KEV</span>{% elif f.risk and f.risk.kev_verified %}não{% else %}?{% endif %}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  <h2>4. Ativos mais críticos</h2>
  {% for a in correlations[:10] %}
  <div class="panel">
    <strong>{{ a.asset }}</strong>
    <span class="muted small">— risco {{ "%.0f"|format(a.max_risk) }} · perspectivas:
      {{ a.perspectives|join(", ") }}
      {% if a.cross_perspective %}<span class="tag ai">Outside-In × Inside-Out</span>{% endif %}</span>
    {% if a.attack_chain %}<p class="small muted" style="margin:3pt 0 0">Cadeia possível (heurística):
      {{ a.attack_chain|join("  →  ") }}</p>{% endif %}
  </div>
  {% endfor %}

  {% if attack %}
  <h2>5. Cobertura MITRE ATT&amp;CK</h2>
  {% if attack.hits %}
  <table>
    <thead><tr><th>Técnica</th><th>Nome</th><th>Tática</th><th>Ocorrências</th></tr></thead>
    <tbody>{% for h in attack.hits %}<tr><td><code>{{ h.technique }}</code></td><td>{{ h.name }}</td>
      <td>{{ h.tactic }}</td><td>{{ h.count }}</td></tr>{% endfor %}</tbody>
  </table>
  <p class="muted small"><strong>Táticas com sinal:</strong> {{ attack.tactics_covered|join(", ") or "nenhuma" }} ·
     <strong>Gap:</strong> {{ attack.tactics_gap|join(", ") or "—" }}
     {% if attack.unmapped %}· Fora do catálogo: {{ attack.unmapped|join(", ") }}{% endif %}</p>
  {% else %}
  <p class="muted small">Nenhuma técnica ATT&amp;CK associada aos findings deste scan.</p>
  {% endif %}
  {% endif %}

  <h2>6. Recomendações</h2>
  <ol>{% for rec in recommendations %}<li>{{ rec }}</li>{% endfor %}</ol>

{% endblock %}
